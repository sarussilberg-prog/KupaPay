{
  "expo": {
    "name": "CoPay",
    "slug": "kupay",
    "scheme": "com.kupay.mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kupay.mobile",
      "associatedDomains": [
        "applinks:kupa.pro"
      ],
      "icon": "./assets/icon.png",
      "infoPlist": {
        "CFBundleDisplayName": "CoPay",
        "CFBundleName": "CoPay",
        "LSApplicationQueriesSchemes": [
          "bit",
          "paybox",
          "PayBox"
        ]
      }
    },
    "android": {
      "package": "com.kupay.mobile",
      "label": "CoPay",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.VIBRATE"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "kupa.pro",
              "pathPattern": "/i/.*"
            },
            {
              "scheme": "https",
              "host": "kupa.pro",
              "pathPattern": "/g/.*"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "name": "CoPay",
      "shortName": "CoPay",
      "description": "Split expenses with friends",
      "themeColor": "#3B82F6",
      "backgroundColor": "#ffffff",
      "display": "standalone",
      "startUrl": "/",
      "lang": "he",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "android": {
            "image": "./assets/splash-icon.png",
            "imageWidth": 200,
            "resizeMode": "contain",
            "backgroundColor": "#ffffff"
          },
          "ios": {
            "image": "./assets/splash-icon.png",
            "imageWidth": 216,
            "resizeMode": "contain",
            "backgroundColor": "#ffffff"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos to set a group or profile image.",
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera to take a receipt photo for an expense.",
          "microphonePermission": false
        }
      ],
      "expo-localization",
      "@react-native-google-signin/google-signin",
      [
        "@sentry/react-native/expo",
        {
          "organization": "kupay-hb",
          "project": "kupa-mobile-prod"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "eb2614a0-ce69-402b-9cbb-668108a9ef27"
      }
    },
    "owner": "saussilberg"
  }
}
