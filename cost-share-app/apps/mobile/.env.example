# Copy to .env and fill from Supabase → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Supabase Dashboard → Authentication → Providers → enable Google
# Authentication → URL Configuration → Redirect URLs (add all you use):
#   com.kupa.mobile://auth/callback
#   exp://YOUR_LAN_IP:8081/--/auth/callback   (Expo Go — see Metro log: [Auth] redirectTo)
#   http://localhost:8081/auth/callback       (Expo Web — local dev)
#   https://kupa.pro/auth/callback              (Expo Web — production)

EXPO_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/idXXXXXXXX
EXPO_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.kupa.mobile
EXPO_PUBLIC_SUPPORT_WHATSAPP_NUMBER=+972528616878

# Profile FX rollup uses open.er-api.com (CORS-safe for Expo Web). No API key required.
