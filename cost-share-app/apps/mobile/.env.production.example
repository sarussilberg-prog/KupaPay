# Copy to .env.production — EAS production builds only (project jfqxjjjbpxbwwvoygahu).
# Sync to EAS secrets:  bash scripts/eas-sync-secrets.sh .env.production
# See docs/SSOT/SUPABASE_ENVIRONMENTS.md and docs/PLAY_STORE_ANDROID.md.

EXPO_PUBLIC_SUPABASE_URL=https://jfqxjjjbpxbwwvoygahu.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_production_publishable_key

EXPO_PUBLIC_WEB_APP_URL=https://kupa.pro
# Google native sign-in (Android). Web application OAuth client ID — same value as Supabase Google provider.
# Web application client (not the Android OAuth client).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=93908207560-8m4mo0bu7edbsh2l9nd6bpbkq6ai2a20.apps.googleusercontent.com
# Supabase Auth → URL Configuration → Redirect URLs (production):
#   com.kupapay.mobile://auth/callback
EXPO_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/idXXXXXXXX
EXPO_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.kupapay.mobile
EXPO_PUBLIC_SUPPORT_EMAIL=sarussilberg@gmail.com

# Sentry error tracking — production project DSN.
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENVIRONMENT=production
