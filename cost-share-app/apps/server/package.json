{
    "name": "@cost-share/server",
    "version": "1.0.0",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only -r dotenv/config src/main.ts",
        "build": "tsc",
        "start": "node -r dotenv/config dist/main.js",
        "clean": "rm -rf dist",
        "seed": "ts-node -r dotenv/config src/scripts/seed.ts",
        "test": "jest",
        "test:watch": "jest --watch"
    },
    "dependencies": {
        "@cost-share/shared": "*",
        "@nestjs/common": "^10.3.0",
        "@nestjs/config": "^3.2.0",
        "@nestjs/core": "^10.3.0",
        "@nestjs/platform-express": "^10.3.0",
        "@supabase/supabase-js": "^2.45.0",
        "dotenv": "^16.4.5",
        "reflect-metadata": "^0.1.13",
        "rxjs": "^7.8.1",
        "ws": "^8.20.1"
    },
    "devDependencies": {
        "@nestjs/testing": "^10.3.0",
        "@types/jest": "^29.5.14",
        "@types/node": "^20.10.6",
        "@types/ws": "^8.18.1",
        "jest": "^29.7.0",
        "ts-jest": "^29.2.5",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3"
    }
}
